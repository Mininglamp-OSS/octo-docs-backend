{
  "name": "@octo/docs-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Octo Docs real-time collaborative document backend (Hocuspocus + Yjs). Implements the FROZEN backend-design contract.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "license:check": "license-checker --onlyAllow 'MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0' --production"
  },
  "dependencies": {
    "@hocuspocus/extension-database": "^4.3.0",
    "@hocuspocus/extension-logger": "^4.3.0",
    "@hocuspocus/extension-redis": "^4.3.0",
    "@hocuspocus/server": "^4.1.2",
    "@tiptap/extension-emoji": "^3.22.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lib0": "^0.2.97",
    "mysql2": "^3.11.3",
    "prosemirror-model": "^1.25.9",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.34.3",
    "ws": "^8.18.0",
    "y-prosemirror": "^1.2.12",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/ws": "^8.5.12",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.2"
  }
}
