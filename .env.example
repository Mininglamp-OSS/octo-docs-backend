# ── Server ──────────────────────────────────────────────────────────────────
HOSTNAME=octo-docs-local
# Hocuspocus collaborative WS server port (§2.1)
HOCUSPOCUS_PORT=1234
# REST metadata API port (§8.4)
HTTP_PORT=3000
# Express `trust proxy` setting (§8.4). The REST API runs behind nginx, so this
# must be set for req.ip — and the per-IP rate limiter — to see the real client
# from X-Forwarded-For rather than the proxy. `1` = one nginx hop (default);
# use the hop count for deeper proxy chains, a CIDR/preset like `loopback`, or
# `false` only when the app is exposed directly. Avoid `true` in prod (permissive:
# lets clients spoof X-Forwarded-For).
TRUST_PROXY=1

# ── CORS (XIN-717) ────────────────────────────────────────────────────────────
# Comma-separated allowlist of front-end origins permitted to call the REST API
# and (with the local-hmac driver pointed at this backend origin) the presigned
# attachment PUT/GET. The browser preflights cross-origin requests with OPTIONS
# and blocks any response whose Access-Control-Allow-Origin does not match, so
# the FE origin MUST be listed here or image upload/download fails. Use exact
# origins (scheme + host + port), e.g. `http://192.168.214.189:3010`, or the
# single value `*` to reflect any origin. Empty (default) allows no cross-origin
# request — set it per environment at deploy time.
# CORS_ALLOWED_ORIGINS=

# ── Rate limiting (§8.4) ──────────────────────────────────────────────────────
# Per-IP throttle on the REST route chains (human /api/v1/docs + bot /v1/bot/docs).
# /healthz is never throttled. Requires TRUST_PROXY set correctly to key per client.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ── MySQL (authoritative store, §3.4) ─────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=octo_docs
MYSQL_PASSWORD=octo_docs
MYSQL_DATABASE=octo_docs
MYSQL_CONNECTION_LIMIT=10

# ── Redis (pub/sub broadcast bus + epoch cache + connection registry, §5) ─────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Multi-product key isolation prefix (§2.1 / §5.1)
REDIS_PREFIX=octo-docs

# ── collab token JWT (§4.4) ───────────────────────────────────────────────────
# docs backend private signing secret for the short-lived collab JWT.
# In production use an asymmetric key / KMS; HS256 secret is for dev only.
COLLAB_TOKEN_SECRET=dev-only-change-me
# collab token TTL in seconds (default 5 minutes per §4.4)
COLLAB_TOKEN_TTL_SECONDS=300
# Public, browser-reachable collab WS origin returned to clients as `collabWsUrl`
# on the collab-token response (§4.4). MUST be an absolute ws:// or wss:// URL —
# the Hocuspocus WS server runs on its own origin (:1234) and is NOT reverse-
# proxied, so a relative path can never reach it. Prod example: wss://collab.example.com
# REQUIRED in production: if unset or malformed the backend fails fast and refuses
# to start (clients have no WS fallback anymore). Optional in local dev only.
COLLAB_TOKEN_PUBLIC_WS_URL=ws://192.168.214.189:1234

# ── octo identity integration (§4.7) ──────────────────────────────────────────
# Identity mode: "http" (cross-service, calls POST /v1/auth/verify) or
# "middleware" (same-process mount behind octo AuthMiddleware — placeholder).
OCTO_IDENTITY_MODE=http
# Base URL of octo-server for the cross-service token introspection fallback.
OCTO_SERVER_BASE_URL=http://127.0.0.1:8080
# Backend service token for octo-server. The backend makes server-side
# octo-server calls: the add-member / forward-grant uid existence check (anti
# ghost-member) in members.ts / forwardGrant.ts.
#   - Human path (/api/v1/docs): OPTIONAL. When empty, that check uses the
#     caller's own session token; collaborator name/avatar display is unaffected
#     (the frontend fetches those from octo-server directly). Setting it is
#     optional hardening only.
#   - Bot path (/v1/bot/docs): REQUIRED. verifyBot does not set a caller token,
#     so the existence check has no session token to fall back on — without this
#     serviceToken, bot add-member / forward-grant fail cleanly with 404
#     user_not_found. Configure it wherever the bot path is deployed.
OCTO_SERVER_TOKEN=

# ── attachments (§3.5) ────────────────────────────────────────────────────────
# Object storage bucket for presigned attachment uploads.
ATTACHMENT_BUCKET=octo-docs-attachments
# Presign driver: 'local-hmac' (default, zero-dependency dev signing) or
# 's3'/'minio' (real AWS SigV4 presigned URLs against an S3-compatible endpoint).
ATTACHMENT_DRIVER=local-hmac
# Optional object-key prefix prepended to every key before signing, so several
# apps can share one bucket (e.g. a Tencent COS bucket shared with octo-server).
# Empty = unprefixed (default; no change for existing deployments).
# ATTACHMENT_KEY_PREFIX=
# Public, browser-reachable base URL the 'local-hmac' driver bakes into the
# signed PUT/GET URL host. The front-end uploads/downloads directly, so this host
# MUST resolve from the end-user browser. Empty (default) uses the legacy
# `https://<bucket>.object-store.local` origin — an internal alias the browser
# cannot resolve (ERR_NAME_NOT_RESOLVED), which breaks cross-device image upload
# (XIN-713). Set it to a reachable host, e.g. the docs-backend origin that fronts
# object storage (`http://<host>:<HTTP_PORT>`) or a real object-store endpoint.
# An optional path segment (e.g. `.../attachments`) is supported. Do NOT commit a
# LAN IP here — set it per-environment at deploy time.
# ATTACHMENT_PUBLIC_BASE_URL=
# Filesystem directory the self-hosted local-hmac blob gateway stores/serves
# uploaded bytes from (XIN-717). Only used when ATTACHMENT_DRIVER=local-hmac AND
# ATTACHMENT_PUBLIC_BASE_URL points at this backend origin, i.e. the browser
# PUTs/GETs the binary directly here. Empty (default) uses
# `<os.tmpdir()>/octo-docs-attachments`. Ignored by the s3/minio drivers.
# ATTACHMENT_LOCAL_DIR=
# HMAC key for the 'local-hmac' driver (signs objectKey + expiry). Dev fallback
# is 'dev-only-change-me'; it MUST be overridden in production — the process
# refuses to start with the dev default when NODE_ENV=production, for ANY driver.
ATTACHMENT_SIGNING_SECRET=dev-only-change-me
# ── S3-compatible (MinIO/S3/COS) driver — used only when ATTACHMENT_DRIVER=s3|minio ─
# Public, browser-reachable endpoint baked into the signed URL host. Do NOT point
# this at a docker-internal alias.
ATTACHMENT_S3_ENDPOINT=http://localhost:9000
ATTACHMENT_S3_REGION=us-east-1
# Credentials — supply real values via env at runtime; never commit them.
ATTACHMENT_S3_ACCESS_KEY=<access-key>
ATTACHMENT_S3_SECRET_KEY=<secret-key>
# Addressing: true (default) = path-style `<endpoint>/<bucket>/<key>` (MinIO).
# false = virtual-hosted / custom-domain `<endpoint>/<key>` (host already bound
# to the bucket, e.g. a Tencent COS CDN domain) — drops the bucket from the path
# and the SigV4 canonicalUri.
# ATTACHMENT_S3_FORCE_PATH_STYLE=true
# Host signed in the SigV4 `host` header when it differs from the endpoint host.
# A COS CDN/custom domain origin-pulls to the bucket with the Host rewritten to
# `<bucket>.cos.<region>.myqcloud.com`, and COS validates against THAT host — set
# this to the origin host while ATTACHMENT_S3_ENDPOINT stays the custom domain.
# Empty (default) signs the endpoint host (MinIO/S3, or COS on its origin).
# ATTACHMENT_S3_SIGNING_HOST=
# Tiered size caps (bytes). Tier is chosen by the backend from the 'image/' mime
# prefix; both tiers hard-cap. Defaults: 10MB image, 50MB file.
ATTACHMENT_MAX_IMAGE_SIZE_BYTES=10485760
ATTACHMENT_MAX_FILE_SIZE_BYTES=52428800
# Presigned PUT (upload) URL TTL and re-issued signed GET (read) URL TTL, seconds.
ATTACHMENT_UPLOAD_URL_TTL_SECONDS=300
ATTACHMENT_READ_URL_TTL_SECONDS=600
# Hard cap on the batch resolve endpoint (over-cap requests are rejected).
ATTACHMENT_MAX_RESOLVE_BATCH=200
# Allowed MIME list. Entry ending in '/' = prefix match; otherwise exact match.
# ATTACHMENT_ALLOWED_MIME_PREFIXES=image/,application/pdf,text/plain,...
# Denylist (takes precedence over the allow list); HTML/script/executable/SVG.
# ATTACHMENT_BLOCKED_MIMES=image/svg+xml,text/html,application/javascript,...

# ── link-card OG fetch (§3.5 ⑰) ───────────────────────────────────────────────
# Outbound OG fetch is SSRF-guarded. These bound the request and the result cache.
OG_FETCH_TIMEOUT_MS=5000
OG_MAX_RESPONSE_BYTES=524288
OG_MAX_REDIRECTS=3
OG_USER_AGENT=octo-docs-linkcard/1.0 (+bot)
OG_ALLOWED_PORTS=80,443
OG_CACHE_SUCCESS_TTL_SECONDS=86400
OG_CACHE_FAILURE_TTL_SECONDS=300

# ── limits (§9.5) ─────────────────────────────────────────────────────────────
# Single-document Yjs state hard cap in bytes (§9.5, ~5-10MB band). Default 10MB.
MAX_DOC_BYTES=10485760

# ── auto-save version history (§5.7) ──────────────────────────────────────────
# Backend-autonomous auto snapshots off the Hocuspocus store path. Default OFF
# (gray release); when disabled the hooks are inert.
AUTO_SNAPSHOT_ENABLED=false
# "stopped typing" idle window (ms) before a clean restore point is taken.
AUTO_IDLE_MS=15000
# Minimum spacing (ms) between two auto snapshots, so continuous editing still
# snapshots periodically.
AUTO_MIN_INTERVAL_MS=60000
# Retention: keep at most the most-recent N auto rows per doc.
AUTO_RETAIN_COUNT=50
# Retention: drop auto rows older than this many days.
AUTO_RETAIN_DAYS=7
